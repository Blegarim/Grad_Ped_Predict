# --- Datasets & large binaries (from OLD .gitignore) ---
# Anchored to repo root so they don't also ignore the src/pedpredict/data/ package.
/PIE/
/data/
*.mp4
*.avi

# --- Virtual environments ---
venv/
.venv/
env/

# --- Python caches / build artifacts ---
__pycache__/
*.py[cod]
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Model weights & serialized data ---
*.pt
*.pth
*.ckpt
*.pkl
*.lmdb
*.mdb
*.onnx
# ...but golden test fixtures (small, versioned parity snapshots) MUST be tracked.
!tests/fixtures/golden/*.pt
!tests/fixtures/golden/*.pkl
# ...and the OLD-repo golden reference samples (subsampled sequences) live in OLD/golden/.
!OLD/golden/*.pkl

# --- Generated LMDB datasets (writer output; content already covered by *.lmdb/*.mdb) ---
/preprocessed_*/

# --- Run artifacts the OLD repo wrongly committed (B11) ---
training_log/
model_outputs/
best_model_outputs/
runs/
outputs/
plots/*.png
qualitative_visualize/
*.xlsx
*.log

# --- Editor / tooling caches ---
.understand-anything/
.claude/settings.local.json
.ipynb_checkpoints/

# --- OS-specific ---
.DS_Store
Thumbs.db
